{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A story mapping project containing multiple plans.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the project."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was last updated."
        },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "title": { "type": "string" },
              "message": { "type": "string" },
              "intention": { "type": "string" },
              "visual": { "type": "string" },
              "color": { "type": "string" },
              "transition": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "ownerId", "createdAt", "updatedAt", "plans"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment left on a specific plan of a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "planId": { "type": "number" },
        "text": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["projectId", "planId", "text", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of story mapping projects."
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Collection of comments on project plans."
    }
  }
}
